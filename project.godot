; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but that's also a valid option.
; Resource paths can be relative or absolute; if absolute, they must be accessible whenever running the project.

config_version=5

[application]

config/name="Dig & Dash"
config/description="A 2D grid-based puzzle-platformer inspired by Lode Runner."
config/features=PackedStringArray("4.6", "GL Compatibility")
config/run/main_scene="res://scenes/levels/level_01.tscn"
config/icon="res://icon.svg"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/initial_screen=0
window/size/mode=0
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

