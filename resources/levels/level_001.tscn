;; ADR-001 — Level 001 data scene (TileMapLayer-first pipeline).
;;
;; TerrainMap uses LevelTileMapBuilder to auto-populate tiles from LevelBuilder
;; during the migration phase. Once this level is fully designed in the Godot
;; editor, replace LevelTileMapBuilder with a plain TileMapLayer and the
;; tile_map_data will be baked directly into this file.
;;
;; Node convention (LevelSceneParser):
;;   TerrainMap  — TileMapLayer (auto-populated by LevelTileMapBuilder._ready)
;;   PlayerSpawn — Node2D at pixel position (col × 32, row × 32)
;;   Exit        — Node2D at pixel position
;;   Enemies/    — Node2D children, one per enemy
;;                 metadata rescate_col / rescate_row override respawn position
;;   Pickups/    — Node2D children, one per treasure
[gd_scene format=3 uid="uid://d7kv3n9t1pq5m"]

[ext_resource type="Script" uid="uid://8rsy71fdctwd" path="res://src/tools/level_tilemap_builder.gd" id="1_ltmb"]
[ext_resource type="TileSet" uid="uid://dig_terrain_tileset" path="res://resources/tilesets/terrain_simple.tres" id="2_tileset"]

[node name="level_001" type="Node"]

[node name="TerrainMap" type="TileMapLayer" parent="."]
tile_set = ExtResource("2_tileset")
script = ExtResource("1_ltmb")
level_id = "level_001"

[node name="PlayerSpawn" type="Node2D" parent="."]
position = Vector2(32, 32)

[node name="Exit" type="Node2D" parent="."]
position = Vector2(256, 160)

[node name="Enemies" type="Node" parent="."]

[node name="Enemy" type="Node2D" parent="Enemies"]
position = Vector2(224, 32)
metadata/rescate_col = 7
metadata/rescate_row = 0

[node name="Pickups" type="Node" parent="."]

[node name="Pickup1" type="Node2D" parent="Pickups"]
position = Vector2(96, 32)

[node name="Pickup2" type="Node2D" parent="Pickups"]
position = Vector2(192, 96)

[node name="Pickup3" type="Node2D" parent="Pickups"]
position = Vector2(128, 160)
